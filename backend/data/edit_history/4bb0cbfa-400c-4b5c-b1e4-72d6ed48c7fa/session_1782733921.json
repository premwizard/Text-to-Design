      "components/Navbar.jsx": "import React, { useState } from 'react';\nimport { Link } from 'react-router-dom';\nimport { MenuAlt2, X } from 'lucide-react';\n\nconst Navbar = () => {\n  const [isOpen, setIsOpen] = useState(false);\n\n  return (\n    <nav className=\"flex justify-between items-center w-full bg-zinc-600 p-4 text-zinc-400\">\n      <div className=\"flex items-center space-x-4 lg:space-x-8\">\n        <Link to=\"/\" className=\"text-lg font-bold text-zinc-400 hover:text-zinc-300\">\n          Apexify\n        </Link>\n        <span className=\"text-sm text-zinc-400\">Transform your business with cutting-edge technology</span>\n      </div>\n\n      <button\n        type=\"button\"\n        className=\"lg:hidden focus:outline-none\"\n        aria-label=\"Toggle menu\"\n        onClick={() => setIsOpen(!isOpen)}\n      >\n        <MenuAlt2 size=\"1.5rem\" />\n      </button>\n\n      <div\n        className={`lg:flex lg:items-center lg:space-x-4 ${isOpen ? 'lg:flex' : 'hidden'}`}\n      >\n        <ul className=\"flex space-x-4\">\n          <li>\n            <Link to=\"/about\" className=\"text-zinc-400 hover:text-zinc-300\">\n              About\n            </Link>\n          </li>\n          <li>\n            <Link to=\"/contact\" className=\"text-zinc-400 hover:text-zinc-300\">\n              Contact\n            </Link>\n          </li>\n        </ul>\n\n        <button\n          type=\"button\"\n          className=\"hidden lg:flex text-zinc-400 hover:text-zinc-300\"\n          aria-label=\"Toggle menu\"\n          onClick={() => setIsOpen(!isOpen)}\n        >\n          <X size=\"1.5rem\" />\n        </button>\n      </div>\n    </nav>\n  );\n};\n\nexport default Navbar;",
      "components/HeroSection.jsx": "import React from 'react';\nimport { Link } from 'react-router-dom';\nimport { Home } from 'lucide-react';\n\nconst HeroTagline = ({ children }) => (\n  <p\n    className=\"text-lg lg:text-2xl text-zinc-400 dark:text-zinc-600 font-sans font-normal\"\n  >\n    {children}\n  </p>\n);\n\nconst HeroSection = () => {\n  return (\n    <section\n      className=\"relative pt-32 md:pt-48 lg:pt-52 xl:pt-64 2xl:pt-72 bg-zinc-600 dark:bg-zinc-900\"\n    >\n      <div className=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\">\n        <div className=\"flex justify-center\">\n          <div className=\"text-center\">\n            <h1 className=\"text-5xl lg:text-6xl xl:text-7xl 2xl:text-8xl text-zinc-100 dark:text-zinc-50 font-sans font-bold\">\n              <span className=\"bg-clip-text text-zinc-600 dark:text-zinc-400 bg-gradient-to-r from-zinc-800 to-zinc-900\">\n                Apexify\n              </span>\n            </h1>\n            <HeroTagline>\n              Transform your business with cutting-edge technology\n            </HeroTagline>\n          </div>\n        </div>\n        <div className=\"mt-12 sm:mt-16 lg:mt-20\">\n          <Link\n            to=\"/\"\n            className=\"bg-zinc-600 hover:bg-zinc-700 text-zinc-100 dark:text-zinc-50 dark:hover:text-zinc-100 font-sans font-bold py-2 px-4 rounded-md\"\n          >\n            Explore\n          </Link>\n        </div>\n      </div>\n    </section>\n  );\n};\n\nexport default HeroSection;",
      "components/BentoFeatures.jsx": "import React from 'react';\nimport { Link } from 'react-router-dom';\nimport { Briefcase, Code, File } from 'lucide-react';\n\nconst BentoFeatures = () => {\n  const [isAccordionOpen, setIsAccordionOpen] = React.useState(false);\n  const [isFeaturesOpen, setIsFeaturesOpen] = React.useState(false);\n\n  const handleAccordionToggle = () => {\n    setIsAccordionOpen(!isAccordionOpen);\n  };\n\n  const handleFeaturesToggle = () => {\n    setIsFeaturesOpen(!isFeaturesOpen);\n  };\n\n  return (\n    <section className=\"max-w-7xl mx-auto py-20\">\n      <div className=\"container mx-auto px-4 md:px-6\">\n        <div className=\"flex flex-wrap justify-center mb-12\">\n          <div className=\"w-full md:w-5/12 lg:w-3/12 xl:w-2/12 p-4 md:p-6\">\n            <div className=\"bg-zinc-600 rounded-md shadow-md hover:bg-zinc-700 transition duration-300\">\n              <div className=\"p-6\">\n                <div className=\"flex items-center mb-4\">\n                  <Briefcase size={24} className=\"text-zinc-400\" />\n                  <h4 className=\"ml-4 text-lg text-zinc-400 font-bold\">Scalable Solutions</h4>\n                </div>\n                <p className=\"text-gray-400\">Built with scalability in mind, our solutions adapt to your business needs.</p>\n              </div>\n            </div>\n          </div>\n          <div className=\"w-full md:w-5/12 lg:w-3/12 xl:w-2/12 p-4 md:p-6\">\n            <div className=\"bg-zinc-600 rounded-md shadow-md hover:bg-zinc-700 transition duration-300\">\n              <div className=\"p-6\">\n                <div className=\"flex items-center mb-4\">\n                  <Code size={24} className=\"text-zinc-400\" />\n                  <h4 className=\"ml-4 text-lg text-zinc-400 font-bold\">Technical Expertise</h4>\n                </div>\n                <p className=\"text-gray-400\">Our team of experts brings cutting-edge technical knowledge to the table.</p>\n              </div>\n            </div>\n          </div>\n          <div className=\"w-full md:w-5/12 lg:w-3/12 xl:w-2/12 p-4 md:p-6\">\n            <div className=\"bg-zinc-600 rounded-md shadow-md hover:bg-zinc-700 transition duration-300\">\n              <div className=\"p-6\">\n                <div className=\"flex items-center mb-4\">\n                  <File size={24} className=\"text-zinc-400\" />\n                  <h4 className=\"ml-4 text-lg text-zinc-400 font-bold\">Customizable Solutions</h4>\n                </div>\n                <p className=\"text-gray-400\">Our solutions can be tailored to fit your specific business needs.</p>\n              </div>\n            </div>\n          </div>\n        </div>\n        <div className=\"flex flex-wrap justify-center mb-12\">\n          <div className=\"w-full md:w-5/12 lg:w-3/12 xl:w-2/12 p-4 md:p-6\">\n            <button\n              className=\"bg-zinc-600 rounded-md shadow-md hover:bg-zinc-700 transition duration-300 py-4 w-full\"\n              onClick={handleAccordionToggle}\n            >\n              <span className=\"flex items-center\">\n                <h4 className=\"mr-2 text-lg text-zinc-400 font-bold\">Discover More</h4>\n                <svg className=\"w-6 h-6 text-zinc-400\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\" xmlns=\"http://www.w3.org/2000/svg\">\n                  <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth=\"2\" d=\"M19 9l-7 7-7-7\" />\n                </svg>\n              </span>\n            </button>\n            {isAccordionOpen && (\n              <div className=\"py-6 bg-zinc-600 rounded-md shadow-md hover:bg-zinc-700 transition duration-300 mb-6\">\n                <div className=\"flex flex-wrap justify-center mb-12\">\n                  <div className=\"w-full md:w-5/12 lg:w-3/12 xl:w-2/12 p-4 md:p-6\">\n                    <div className=\"bg-zinc-600 rounded-md shadow-md hover:bg-zinc-700 transition duration-300\">\n                      <div className=\"p-6\">\n                        <div className=\"flex items-center mb-4\">\n                          <File size={24} className=\"text-zinc-400\" />\n                          <h4 className=\"ml-4 text-lg text-zinc-400 font-bold\">Customizable Solutions</h4>\n                        </div>\n                        <p className=\"text-gray-400\">Our solutions can be tailored to fit your specific business needs.</p>\n                      </div>\n                    </div>\n                  </div>\n                  <div className=\"w-full md:w-5/12 lg:w-3/12 xl:w-2/12 p-4 md:p-6\">\n                    <div className=\"bg-zinc-600 rounded-md shadow-md hover:bg-zinc-700 transition duration-300\">\n                      <div className=\"p-6\">\n                        <div className=\"flex items-center mb-4\">\n                          <Code size={24} className=\"text-zinc-400\" />\n                          <h4 className=\"ml-4 text-lg text-zinc-400 font-bold\">Technical Expertise</h4>\n                        </div>\n                        <p className=\"text-gray-400\">Our team of experts brings cutting-edge technical knowledge to the table.</p>\n                      </div>\n                    </div>\n                  </div>\n                </div>\n              </div>\n            )}\n          </div>\n          <div className=\"w-full md:w-5/12 lg:w-3/12 xl:w-2/12 p-4 md:p-6\">\n            <button\n              className=\"bg-zinc-600 rounded-md shadow-md hover:bg-zinc-700 transition duration-300 py-4 w-full\"\n              onClick={handleFeaturesToggle}\n            >\n              <span className=\"flex items-center\">\n                <h4 className=\"mr-2 text-lg text-zinc-400 font-bold\">View All Features</h4>\n                <svg className=\"w-6 h-6 text-zinc-400\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\" xmlns=\"http://www.w3.org/2000/svg\">\n                  <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth=\"2\" d=\"M19 9l-7 7-7-7\" />\n                </svg>\n              </span>\n            </button>\n            {isFeaturesOpen && (\n              <div className=\"py-6 bg-zinc-600 rounded-md shadow-md hover:bg-zinc-700 transition duration-300 mb-6\">\n                <div className=\"flex flex-wrap justify-center mb-12\">\n                  <div className=\"w-full md:w-5/12 lg:w-3/12 xl:w-2/12 p-4 md:p-6\">\n                    <div className=\"bg-zinc-600 rounded-md shadow-md hover:bg-zinc-700 transition duration-300\">\n                      <div className=\"p-6\">\n                        <div className=\"flex items-center mb-4\">\n                          <File size={24} className=\"text-zinc-400\" />\n                          <h4 className=\"ml-4 text-lg text-zinc-400 font-bold\">Customizable Solutions</h4>\n                        </div>\n                        <p className=\"text-gray-400\">Our solutions can be tailored to fit your specific business needs.</p>\n                      </div>\n                    </div>\n                  </div>\n                  <div className=\"w-full md:w-5/12 lg:w-3/12 xl:w-2/12 p-4 md:p-6\">\n                    <div className=\"bg-zinc-600 rounded-md shadow-md hover:bg-zinc-700 transition duration-300\">\n                      <div className=\"p-6\">\n                        <div className=\"flex items-center mb-4\">\n                          <Code size={24} className=\"text-zinc-400\" />\n                          <h4 className=\"ml-4 text-lg text-zinc-400 font-bold\">Technical Expertise</h4>\n                        </div>\n                        <p className=\"text-gray-400\">Our team of experts brings cutting-edge technical knowledge to the table.</p>\n                      </div>\n                    </div>\n                  </div>\n                </div>\n              </div>\n            )}\n          </div>\n        </div>\n      </div>\n    </section>\n  );\n};\n\nexport default BentoFeatures;"